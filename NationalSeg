#Dissimilarity func
dissimilarity_by_unit <- function(data_long, group_a, group_b,
                                  unit_col = "unit", group_col = "race", n_col = "n") {
  wide <- data_long %>%
    filter(.data[[group_col]] %in% c(group_a, group_b)) %>%
    select(all_of(c(unit_col, group_col, n_col))) %>%
    pivot_wider(names_from = all_of(group_col), values_from = all_of(n_col), values_fill = 0)
  
  if (!group_a %in% names(wide)) wide[[group_a]] <- 0
  if (!group_b %in% names(wide)) wide[[group_b]] <- 0
  
  Xa <- sum(wide[[group_a]], na.rm = TRUE)
  Xb <- sum(wide[[group_b]], na.rm = TRUE)
  
  if (Xa == 0 || Xb == 0) return(NA_real_)
  0.5 * sum(abs((wide[[group_a]] / Xa) - (wide[[group_b]] / Xb)), na.rm = TRUE)
}

