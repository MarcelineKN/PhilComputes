#refresh national comparison tables
#I broke the formatting - this function fixes it
mh_total_to_row <- function(x, method, year, dataset) {
  df <- as_tibble(x)
  
  out <- if (all(c("M","H") %in% names(df))) {
    df %>% select(M, H)
  } else if ("stat" %in% names(df) && "est" %in% names(df)) {
    df %>% select(stat, est) %>% pivot_wider(names_from = stat, values_from = est)
  } else if ("stat" %in% names(df) && "estimate" %in% names(df)) {
    df %>% select(stat, estimate) %>% pivot_wider(names_from = stat, values_from = estimate)
  } else {
    stop("Unexpected mutual_total() output columns: ", paste(names(df), collapse = ", "))
  }
  
  out %>%
    transmute(
      unit = "US_states",
      method = method,
      M = M,
      H = H,
      year = year,
      dataset = dataset,
      geography = "States as unit"
    )
}

