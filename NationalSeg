#Build P8 variable and convert clean combo label map
vars <- load_variables(year = 2020, dataset = "dhc", cache = TRUE)

p8_vars <- vars %>%
  filter(str_detect(name, "^P8_")) %>%
  select(variable = name, label)

clean_p8_label <- function(x) {
  x %>%
    str_replace_all("^.*?!!", "") %>%
    str_replace_all("!!", " / ") %>%
    str_squish()
}

p8_map <- p8_vars %>%
  mutate(combo = clean_p8_label(label))

#Leaf-only filter: drop total/subtotal hierarchy rows
keep_leaf_combo <- function(combo) {
  if (combo %in% c("Total:", "Total")) return(FALSE)
  if (str_count(combo, "/") == 0) return(FALSE)                        # grand total
  if (str_detect(combo, regex(":\\s*$", ignore_case = TRUE))) return(FALSE)  # subtotal headers
  TRUE
}

#Pull one state's P8, convert to state-by-combo long, aggregate tract counts up to the state
get_state_combo_long_states_unit <- function(st) {
  race_raw <- get_decennial(
    geography = "tract",
    state = st,
    year = 2020,
    sumfile = "dhc",
    table = "P8",
    geometry = FALSE,
    output = "wide"
  )
  
  race_raw %>%
    pivot_longer(
      cols = starts_with("P8_"),
      names_to = "variable",
      values_to = "n"
    ) %>%
    left_join(p8_map, by = "variable") %>%
    transmute(
      unit = substr(GEOID, 1, 2),   # state FIPS as "unit"
      state = st,
      combo,
      n
    ) %>%
    filter(!is.na(combo), !is.na(n), n > 0) %>%
    filter(vapply(combo, keep_leaf_combo, logical(1))) %>%
    group_by(unit, state, combo) %>%
    summarise(n = sum(n, na.rm = TRUE), .groups = "drop")
}

