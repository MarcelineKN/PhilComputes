get_state_base_any <- function(st) {
  base <- get_acs(
    geography = "state",
    state = st,
    variables = vars_base,
    year = 2019,
    survey = "acs5",
    output = "wide"
  ) %>%
    transmute(
      unit = GEOID,     # state GEOID
      state = st,
      total = totalE,
      multiracial = multiracialE
    )
  
  any <- get_acs(
    geography = "state",
    state = st,
    variables = vars_combo,
    year = 2019,
    survey = "acs5",
    output = "wide"
  ) %>%
    transmute(
      unit = GEOID,
      state = st,
      white_any     = white_anyE,
      black_any     = black_anyE,
      native_am_any = native_am_anyE,
      asian_any     = asian_anyE,
      pacific_any   = pacific_anyE,
      other_any     = other_anyE
    )
  
  left_join(base, any, by = c("unit", "state"))
}

us_state_base_any <- map_dfr(states_50dc, get_state_base_any)

#State-level weights based on any combination totals within each state
us_state_weights_any <- us_state_base_any %>%
  rowwise() %>%
  mutate(
    denom_any = sum(c_across(white_any:other_any), na.rm = TRUE),
    w_white_any     = ifelse(denom_any > 0, white_any     / denom_any, NA_real_),
    w_black_any     = ifelse(denom_any > 0, black_any     / denom_any, NA_real_),
    w_native_am_any = ifelse(denom_any > 0, native_am_any / denom_any, NA_real_),
    w_asian_any     = ifelse(denom_any > 0, asian_any     / denom_any, NA_real_),
    w_pacific_any   = ifelse(denom_any > 0, pacific_any   / denom_any, NA_real_),
    w_other_any     = ifelse(denom_any > 0, other_any     / denom_any, NA_real_)
  ) %>%
  ungroup()

#Fractionally allocate each state's multiracial bucket into any combination races
us_state_race_frac_any_long <- us_state_weights_any %>%
  mutate(
    white_f     = white_any     + multiracial * w_white_any,
    black_f     = black_any     + multiracial * w_black_any,
    native_am_f = native_am_any + multiracial * w_native_am_any,
    asian_f     = asian_any     + multiracial * w_asian_any,
    pacific_f   = pacific_any   + multiracial * w_pacific_any,
    other_f     = other_any     + multiracial * w_other_any
  ) %>%
  select(unit, state, white_f, black_f, native_am_f, asian_f, pacific_f, other_f) %>%
  pivot_longer(
    cols = ends_with("_f"),
    names_to = "race",
    values_to = "n"
  ) %>%
  mutate(race = sub("_f$", "", race)) %>%
  filter(!is.na(n), n > 0)

