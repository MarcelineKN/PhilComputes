ggplot(
  mh_plot_long_chi,
  aes(x = method, y = value, color = county_name, group = county_name)
) +
  geom_point(size = 3) +
  geom_line(alpha = 0.5) +
  facet_wrap(~ index, scales = "free_y") +
  labs(
    x = "Multiracial assignment method",
    y = "Segregation index value",
    color = "County"
  ) +
  scale_x_discrete(labels = function(x) str_wrap(x, width = 30), drop = FALSE) +
  theme_minimal() +
  theme(
    axis.text.x = element_text(angle = 45, hjust = 1),
    panel.grid.minor = element_blank()
  )

