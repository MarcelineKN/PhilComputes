# Pull P9 (Hispanic origin by race) from DHC
p9_raw <- get_decennial(
  geography = "tract",
  state = "HI",
  year = 2020,
  sumfile = "dhc",
  table = "P9",
  geometry = FALSE,
  output = "wide"
)

vars <- load_variables(year = 2020, dataset = "dhc", cache = TRUE)

p9_vars <- vars %>%
  filter(str_detect(name, "^P9_")) %>%
  select(name, label)

priority <- c(
  "Black or African American",
  "Native Hawaiian and Other Pacific Islander",
  "American Indian and Alaska Native",
  "Asian",
  "Some Other Race",
  "White"
)

detect_races <- function(lbl, races) {
  races[str_detect(lbl, fixed(races, ignore_case = TRUE))]
}

assign_group_p9 <- function(lbl, priority) {
  is_hisp <- str_detect(lbl, regex("Hispanic or Latino", ignore_case = TRUE))
  is_nonh <- str_detect(lbl, regex("Not Hispanic or Latino", ignore_case = TRUE))
  
  # Skip totals / headers that don't describe a race row
  if (!is_hisp && !is_nonh) return(NA_character_)
  
  # Hispanic handling
  if (is_hisp) {
    has_black <- str_detect(lbl, fixed("Black or African American", ignore_case = TRUE))
    if (has_black) return("Black or African American")
    return("Hispanic")
  }
  
  # Not Hispanic: assign by stigma-priority race
  present <- detect_races(lbl, priority)
  if (length(present) == 0) return(NA_character_)
  present[1]
}

p9_map <- p9_vars %>%
  mutate(assigned_group = vapply(label, assign_group_p9, character(1), priority = priority)) %>%
  filter(!is.na(assigned_group))

p9_long <- p9_raw %>%
  pivot_longer(
    cols = starts_with("P9_"),
    names_to = "variable",
    values_to = "n"
  ) %>%
  left_join(p9_map, by = c("variable" = "name")) %>%
  filter(!is.na(assigned_group)) %>%
  group_by(GEOID, assigned_group) %>%
  summarise(n = sum(n, na.rm = TRUE), .groups = "drop")

