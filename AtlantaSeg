  output = "wide"
) %>%
  transmute(
    GEOID,
    white_any     = white_anyE,
    black_any     = black_anyE,
    native_am_any = native_am_anyE,
    asian_any     = asian_anyE,
    pacific_any   = pacific_anyE,
    other_any     = other_anyE,
    tract  = GEOID,
    county = substr(GEOID, 1, 5)
  ) %>%
  filter(county %in% atlanta_county_fips)

county_race_weights_any_atl <- atl_any %>%
  group_by(county) %>%
  summarise(
    white_any     = sum(white_any, na.rm = TRUE),
    black_any     = sum(black_any, na.rm = TRUE),
    native_am_any = sum(native_am_any, na.rm = TRUE),
    asian_any     = sum(asian_any, na.rm = TRUE),
    pacific_any   = sum(pacific_any, na.rm = TRUE),
    other_any     = sum(other_any, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  rowwise() %>%
  mutate(
    denom_any = sum(c_across(white_any:other_any)),
    across(
      white_any:other_any,
      ~ ifelse(denom_any > 0, .x / denom_any, NA_real_),
      .names = "w_{.col}"
    )
  ) %>%
  ungroup() %>%
  select(county, starts_with("w_"))

atl_tract_race_frac_any <- atl_base %>%
  left_join(
    atl_any %>%
      select(
        tract, GEOID, county,
        white_any, black_any, native_am_any, asian_any, pacific_any, other_any
      ),
    by = c("tract", "GEOID", "county")
  ) %>%
  left_join(county_race_weights_any_atl, by = "county") %>%
  mutate(
    white_f     = white_any     + multiracial * w_white_any,
    black_f     = black_any     + multiracial * w_black_any,
    native_am_f = native_am_any + multiracial * w_native_am_any,
    asian_f     = asian_any     + multiracial * w_asian_any,
    pacific_f   = pacific_any   + multiracial * w_pacific_any,
    other_f     = other_any     + multiracial * w_other_any
  ) %>%
  select(
    tract,
    county,
    white_f, black_f, native_am_f, asian_f, pacific_f, other_f
  )

