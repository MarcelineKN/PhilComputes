priority <- c(
  "Black or African American",
  "Native Hawaiian and Other Pacific Islander",
  "American Indian and Alaska Native",
  "Asian",
  "Some Other Race",
  "White"
)

race_raw <- get_decennial(
  geography = "tract",
  state = "GA",
  year = 2020,
  sumfile = "dhc",
  table = "P8",
  geometry = FALSE,
  output = "wide"
)

vars <- load_variables(year = 2020, dataset = "dhc", cache = TRUE)

p8_vars <- vars %>%
  filter(str_detect(name, "^P8_")) %>%
  select(name, label)

detect_races <- function(lbl, races) {
  present <- races[str_detect(lbl, fixed(races, ignore_case = TRUE))]
  present
}

assign_group <- function(lbl, priority) {
  present <- detect_races(lbl, priority)
  if (length(present) == 0) return(NA_character_)
  present[1]
}

p8_map <- p8_vars %>%
  mutate(
    assigned_group = vapply(label, assign_group, character(1), priority = priority)
  ) %>%
  filter(!is.na(assigned_group))

atl_race_long <- race_raw %>%
  pivot_longer(
    cols = starts_with("P8_"),
    names_to = "variable",
    values_to = "n"
  ) %>%
  left_join(p8_map, by = c("variable" = "name")) %>%
  transmute(
    tract = GEOID,
    county = substr(GEOID, 1, 5),
    assigned_group,
    n
  ) %>%
  filter(
    county %in% atlanta_county_fips,
    !is.na(assigned_group),
    !is.na(n),
    n > 0
  ) %>%
  group_by(tract, county, assigned_group) %>%
  summarise(n = sum(n, na.rm = TRUE), .groups = "drop")

forced_reassign_mh_atl <- mutual_total(
