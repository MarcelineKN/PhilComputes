dissimilarity_by_county <- function(data_long, group_a, group_b, county_col = "county",
                                    unit_col = "tract", group_col = "race", n_col = "n") {
  wide <- data_long %>%
    filter(.data[[group_col]] %in% c(group_a, group_b)) %>%
    select(all_of(c(county_col, unit_col, group_col, n_col))) %>%
    pivot_wider(names_from = all_of(group_col), values_from = all_of(n_col), values_fill = 0)
  
  if (!group_a %in% names(wide)) wide[[group_a]] <- 0
  if (!group_b %in% names(wide)) wide[[group_b]] <- 0
  
  wide %>%
    group_by(.data[[county_col]]) %>%
    summarise(
      D = {
        Xa <- sum(.data[[group_a]], na.rm = TRUE)
        Xb <- sum(.data[[group_b]], na.rm = TRUE)
        if (Xa == 0 || Xb == 0) NA_real_ else {
          0.5 * sum(abs((.data[[group_a]] / Xa) - (.data[[group_b]] / Xb)), na.rm = TRUE)
        }
      },
      .groups = "drop"
    ) %>%
    rename(county = all_of(county_col))
}

